          "@id": "llm_speedrun_records/id",
          "name": "id",
          "description": "The nanoGPT speedrun record ID",
          "dataType": "sc:Integer",
          "source": {
            "fileObject": {
              "@id": "data"
            },
            "extract": {
              "column": "id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "llm_speedrun_records/current_results",
          "name": "current_results",
          "description": "JSON output for the current record",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "data"
            },
            "extract": {
              "column": "current_results"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "llm_speedrun_records/current_train_script",
          "name": "current_train_script",
          "description": "Python script used to train the model for the current record",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "data"
            },
            "extract": {
              "column": "current_train_script"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "llm_speedrun_records/hint",
          "name": "hint",
          "description": "The hint for the next record",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "data"
            },
            "extract": {
              "column": "hint"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "llm_speedrun_records/current_results_path",
          "name": "current_results_path",
          "description": "The local path to the JSON output for the current record",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "data"
            },
            "extract": {
