    "cmap = plt.get_cmap('tab10')\n",
    "fig, ax = plt.subplots()\n",
    "x_list = list(range(5, 12))\n",
    "\n",
    "# Calculate percentage reduction from prev human to human for both agents\n",
    "reductions_l1 = {}\n",
    "reductions_codediff = {}\n",
    "\n",
    "for k in agent_l1_record.keys():\n",
    "    if k in prev_human_train_time_dict and k in new_human_train_time_dict:\n",
    "        prev_time = prev_human_train_time_dict[k]\n",
    "        new_time = new_human_train_time_dict[k]\n",
    "        reduction_l1 = ((prev_time - agent_l1_record[k]) / (prev_time - new_time)) * 100\n",
    "        reduction_codediff = ((prev_time - agent_record[k]) / (prev_time - new_time)) * 100\n",
    "        reductions_l1[k] = reduction_l1\n",
    "        reductions_codediff[k] = reduction_codediff\n",
    "\n",
    "# Set width of bars\n",
    "bar_width = 0.35\n",
    "\n",
    "# Set position of bar on X axis\n",
    "r1 = np.arange(len(reductions_l1))\n",
    "r2 = [x + bar_width for x in r1]\n",
    "\n",
    "# Create bars with positive and negative colors\n",
    "for i, (l1_val, cd_val) in enumerate(zip(reductions_l1.values(), reductions_codediff.values())):\n",
    "    # Pseudocode Knowledge bars\n",
    "    bar1 = ax.bar(r1[i], l1_val, bar_width, color=cmap(1), alpha=0.7)\n",
    "    \n",
    "    # Add text for Pseudocode Knowledge bars\n",
    "    if abs(l1_val) < 2:\n",
    "        ax.text(r1[i], l1_val, '≈0%', ha='center', va='bottom' if l1_val >= 0 else 'top', fontsize=8)\n",
    "    else:\n",
    "        ax.text(r1[i], l1_val, f'{l1_val:.1f}%', ha='center', va='bottom' if l1_val >= 0 else 'top', fontsize=8)\n",
    "    \n",
    "    # CodeDiff Knowledge bars  \n",
    "    bar2 = ax.bar(r2[i], cd_val, bar_width, color=cmap(0), alpha=0.7)\n",
    "    \n",
    "    # Add text for CodeDiff Knowledge bars\n",
    "    if abs(cd_val) < 2:\n",
    "        ax.text(r2[i], cd_val, '≈0%', ha='center', va='bottom' if cd_val >= 0 else 'top', fontsize=8)\n",
    "    else:\n",
    "        ax.text(r2[i], cd_val, f'{cd_val:.1f}%', ha='center', va='bottom' if cd_val >= 0 else 'top', fontsize=8)\n",
    "\n",
    "# Add dummy bars for legend\n",
    "ax.bar([-1], [0], bar_width, label='Pseudocode Knowledge', color=cmap(1), alpha=0.7)\n",
    "ax.bar([-1], [0], bar_width, label='CodeDiff Knowledge', color=cmap(0), alpha=0.7)\n",
    "\n",
    "# Add labels\n",
    "ax.set_xlabel('Record number', fontsize=10)\n",
    "ax.set_ylabel('Reduction in Train Time (%)', fontsize=10)\n",
    "ax.set_title('Percentage Reduction in Training Time vs Previous Human', fontsize=10)\n",
    "ax.set_xticks([r + bar_width/2 for r in range(len(reductions_l1))])\n",
    "ax.set_xticklabels(reductions_l1.keys(), fontsize=8)\n",
    "ax.tick_params(axis='y', labelsize=8)\n",
    "\n",
    "ax.grid(True, axis='y')\n",
    "ax.legend(fontsize=8)\n",
    "\n",
    "plt.savefig('reduction_comparison.jpg', dpi=100)"
   ]
